# .env.example — Bu dosya git'e gider (şablon olarak)
# Gerçek .env dosyasını bu şablondan oluştur, asla commit etme!

# Telegram Bot Bildirimleri
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Flask Gizli Anahtar (session güvenliği için)
SECRET_KEY=change_this_to_a_random_secret_key

# Open Food Facts (şu an gerekmez, gelecekte auth için)
# OPENFOODFACTS_API_KEY=
